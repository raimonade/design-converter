{
  "name": "figma-ai-designer",
  "version": "0.1.0",
  "description": "Open-source AI-powered Figma design generator with multi-model support",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:plugin\" \"npm run dev:ui\"",
    "dev:plugin": "vite build --config vite.config.plugin.ts --watch --mode development",
    "dev:ui": "vite --config vite.config.ui.ts",
    "build": "npm run build:plugin && npm run build:ui",
    "build:plugin": "vite build --config vite.config.plugin.ts",
    "build:ui": "vite build --config vite.config.ui.ts",
    "proxy": "node proxy/server.js",
    "services": "node service-manager/server.js",
    "test": "node tests/test-plugin.js",
    "test:fix": "node tests/test-plugin.js --fix"
  },
  "dependencies": {
    "preact": "^10.25.4",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.106.0",
    "@preact/preset-vite": "^2.10.2",
    "@tailwindcss/vite": "^4.0.0",
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vite-plugin-singlefile": "^2.1.0",
    "tailwindcss": "^4.0.0"
  },
  "license": "MIT"
}
